# Server
SERVER_PORT=8080

# Rate limits (requests per second)
RATE_LIMIT_IP=10
RATE_LIMIT_TOKEN_DEFAULT=100
RATE_WINDOW=1s

# Per-token overrides as JSON map: {"token-value": limit}
TOKEN_LIMITS={"premium-token":100,"basic-token":20}

# Block duration after exceeding the limit
BLOCK_DURATION=5m

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
